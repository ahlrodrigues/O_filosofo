MASTODON_BASE_URL=https://seu.servidor.mastodon
MASTODON_TOKEN=cole_seu_token_aqui

# alternate | pt_br | en | bilingual
BOT_MODE=alternate

# true/false: não publica, só mostra preview
DRY_RUN=true

# Caminho do JSON com frases (padrão: quotes_bilingue.json)
QUOTES_FILE=quotes_bilingue.json

# Visibilidade do Mastodon (public | unlisted | private | direct)
MASTODON_VISIBILITY=public

# Tags (hashtags) por idioma
TAG_PT_BR=#filosofia
TAG_EN=#philosophy
